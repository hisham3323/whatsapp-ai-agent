# Application
PROJECT_NAME="WhatsApp AI Sales Agent"
ENVIRONMENT="development"
DEBUG=True

# OpenRouter API
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN="your_custom_webhook_verify_token"
WHATSAPP_ACCESS_TOKEN="your_meta_system_user_access_token"
WHATSAPP_PHONE_NUMBER_ID="your_whatsapp_phone_id"
WHATSAPP_API_VERSION="v18.0"

# PostgreSQL Database
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/whatsapp_agent"

# Redis
REDIS_URL="redis://localhost:6379/0"